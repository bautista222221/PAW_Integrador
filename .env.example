# Datos de Log
LOG_LEVEL=DEBUG
LOG_PATH="/log/app.log"

# Datos de la DB
DB_ADAPTER=mysql
DB_HOSTNAME=localhost
DB_NAME=nombre_base_datos
DB_USERNAME=usuario_base_datos
DB_PASSWORD=contraseña_base_datos
DB_PORT=3306
DB_CHARSET=utf8

# Configuración de Inteligencia Artificial (IA)
IA_KEY=tu_clave_ia
IA_PROVIDER=gemini # Opciones: gemini, openai, openrouter
IA_MODEL=gemini-1.5-flash # Ejemplo: gemini-1.5-flash, gpt-4o-mini, meta-llama/llama-3-8b-instruct
IA_DEBUG=true # true para guardar logs detallados de peticiones/respuestas a la IA en el archivo de log

# Configuración de Cloudinary (Subida externa opcional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=